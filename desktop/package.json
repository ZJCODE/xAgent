{
  "name": "xagent-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for the xAgent web client",
  "author": "ZJun",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "build:mac": "electron-builder --mac dmg --publish never",
    "build:mac:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --publish never",
    "build:win": "electron-builder --win nsis --publish never",
    "build:linux": "electron-builder --linux AppImage --publish never",
    "build:all": "electron-builder -mwl --publish never"
  },
  "build": {
    "appId": "dev.xagent.desktop",
    "productName": "xAgent",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "artifactName": "xAgent-${version}-mac-${arch}.${ext}"
    },
    "dmg": {
      "title": "xAgent ${version}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "xAgent-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "executableName": "xagent-desktop",
      "artifactName": "xAgent-${version}-linux-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  }
}
